# Dashboard
PORT=4173

# Public REST API. Required only when calling /api/v1/xhs/*.
XHS_API_TOKEN=change-me

# Comment generation provider.
# Leave unset to use the local rule-based draft provider.
# COMMENT_PROVIDER=ark
# ARK_API_KEY=
# ARK_MODEL=
# ARK_RELEVANCE_MODEL=
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Optional concurrency controls.
# COMMENT_GENERATION_CONCURRENCY=3
# GENERATE_PUBLISH_CONCURRENCY=3

# Optional content research/publishing overrides.
# WEB_RESEARCH_PROVIDER=playwright
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=
# CHROME_BIN=
# XHS_PUBLISH_COMMAND=python3
# XHS_PUBLISH_SCRIPT_PATH=
# XHS_PUBLISH_ACCOUNT=
